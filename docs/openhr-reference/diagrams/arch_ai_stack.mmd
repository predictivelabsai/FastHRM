flowchart TB
    subgraph Data["Raw data layer"]
      CRM["CRM records"]
      Docs["Documents<br/>(SharePoint)"]
      Market["Market data<br/>(Snowflake)"]
    end

    subgraph Semantic["Semantic layer"]
      Onto["CRE Ontology<br/>Property | Lease | Tenant | Market<br/>BrokerEngagement | Portfolio | Comp"]
